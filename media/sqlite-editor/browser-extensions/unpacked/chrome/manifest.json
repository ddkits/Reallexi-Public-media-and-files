{
  "manifest_version": 3,
  "name": "Reallexi SQLite Editor",
  "short_name": "SQLite Editor",
  "version": "0.1.21",
  "description": "Open, inspect, query, and export local SQLite database files in Chrome.",
  "action": {
    "default_title": "Reallexi SQLite Editor",
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "options_page": "editor.html",
  "homepage_url": "https://reallexi.io/sqlite-editor-vscode",
  "offline_enabled": true,
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; base-uri 'self'; form-action 'self'"
  },
  "minimum_chrome_version": "109"
}
